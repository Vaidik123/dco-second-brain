# Copy this to .env and fill in your values

# Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI — for embeddings
VOYAGE_API_KEY=pa-dkMHrVi0nl2du5W9yhoXNs3OC-To7R1uswAavbcDtWH

# PostgreSQL (Supabase connection string)
# Get from: Supabase project → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Slack — optional, enables real-time #research ingestion and /wiki command
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Twitter — optional, enables @Decentralisedco tweet ingestion
TWITTER_BEARER_TOKEN=

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app
